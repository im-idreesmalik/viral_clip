# ============================================================================
# ViralCut — Environment Configuration
# Copy this file to `.env` and fill in the values. NEVER commit real secrets.
# ============================================================================

# ---- Core ------------------------------------------------------------------
NODE_ENV=development
# Public base URL of the app (used for OAuth redirect URIs and absolute links).
# Localhost for local dev, or your public domain/tunnel in production.
APP_URL=http://localhost:3000

# ---- Database (PostgreSQL) -------------------------------------------------
# Matches docker-compose.yml defaults.
DATABASE_URL=postgresql://viralcut:viralcut@localhost:5432/viralcut?schema=public

# ---- Redis (BullMQ job queue) ----------------------------------------------
REDIS_URL=redis://localhost:6379

# ---- Auth ------------------------------------------------------------------
# 32+ char random string. Generate: `openssl rand -base64 48`
AUTH_SECRET=replace-with-a-long-random-secret-string-min-32-chars
# Session lifetime in days
AUTH_SESSION_DAYS=30

# ---- Encryption ------------------------------------------------------------
# 32-byte key, hex or base64, used to encrypt stored OAuth tokens at rest.
# Generate: `openssl rand -hex 32`
ENCRYPTION_KEY=replace-with-32-byte-hex-or-base64-key

# ---- Storage ---------------------------------------------------------------
# Directory (relative to project root or absolute) for uploaded + generated media.
STORAGE_DIR=./storage
# Optional public base for serving media (e.g. your public domain/CDN). If empty,
# files are served via the app's /api/media route.
MEDIA_PUBLIC_BASE=

# ---- Media tooling ---------------------------------------------------------
# Leave blank to use the bundled ffmpeg-static / ffprobe-static binaries.
# Set to a system path to override (e.g. /usr/bin/ffmpeg).
FFMPEG_PATH=
FFPROBE_PATH=
# Path to a yt-dlp binary. Leave blank to use the binary bundled by
# youtube-dl-exec. Required for downloading YouTube URLs.
YTDLP_PATH=

# ---- AI clip detection -----------------------------------------------------
# Provider: ollama (local + free, default) | anthropic (cloud, paid)
AI_PROVIDER=ollama

# Local LLM via Ollama (https://ollama.com). Install Ollama, then:
#   ollama pull llama3.1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
# Context window the model uses (raise for long transcripts; needs more RAM/VRAM).
OLLAMA_NUM_CTX=8192

# Cloud fallback (only used when AI_PROVIDER=anthropic):
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ---- Transcription ---------------------------------------------------------
# Provider for speech-to-text (transcript + word-level caption timings):
#   transformers -> local Whisper via @huggingface/transformers (default, free,
#                   no Python/binaries; model auto-downloads + caches on 1st run)
#   local        -> local whisper.cpp CLI (set WHISPER_CLI / WHISPER_MODEL)
#   openai       -> OpenAI Whisper API (paid; set OPENAI_API_KEY)
#   none         -> skip transcription (no captions; viral mode uses segmentation)
TRANSCRIPTION_PROVIDER=transformers
# Local model id. small.en = good accuracy + fast on a multicore CPU.
# Use Xenova/whisper-medium.en / large-v3 for more accuracy, or whisper-base for speed.
TRANSFORMERS_WHISPER_MODEL=Xenova/whisper-small.en
# Whisper execution device: cpu (reliable, default) | dml (DirectML GPU on Windows)
# | cuda | webgpu. Falls back to cpu automatically if the device fails to load.
TRANSFORMERS_DEVICE=cpu
TRANSFORMERS_DTYPE=q8

# For TRANSCRIPTION_PROVIDER=openai (paid):
OPENAI_API_KEY=
OPENAI_WHISPER_MODEL=whisper-1
# For TRANSCRIPTION_PROVIDER=local (whisper.cpp):
WHISPER_CLI=
WHISPER_MODEL=

# ---- Worker concurrency ----------------------------------------------------
VIDEO_WORKER_CONCURRENCY=1
PUBLISH_WORKER_CONCURRENCY=2

# ============================================================================
# Social platform OAuth credentials.
# Each requires a registered developer app on the respective platform.
# Redirect URI to register: {APP_URL}/api/social/callback/{platform}
# e.g. http://localhost:3000/api/social/callback/youtube
# Publishing is disabled for a platform until its credentials are set.
# ============================================================================

# ---- YouTube (Google Cloud / YouTube Data API v3) --------------------------
YOUTUBE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your-google-oauth-client-secret

# ---- TikTok (developers.tiktok.com — Content Posting API) ------------------
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret

# ---- Instagram (Instagram API with Instagram Login) ------------------------
# Dashboard -> Instagram product -> "API setup with Instagram login".
# Distinct from the Meta (Facebook) app credentials below.
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret

# ---- Meta (Facebook Reels via Graph API) -----------------------------------
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# TikTok "URL properties" meta-tag verification code (from the Verify URL properties screen)
TIKTOK_URL_VERIFICATION=
