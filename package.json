{
  "name": "viralcut",
  "version": "1.0.0",
  "private": true,
  "description": "Convert long-form videos into viral short-form social media content",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "worker": "tsx src/workers/index.ts",
    "worker:dev": "tsx watch src/workers/index.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "setup": "prisma generate && prisma migrate deploy",
    "setup:local": "tsx scripts/setup-local.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.0",
    "@huggingface/transformers": "^3.3.0",
    "@prisma/client": "^6.3.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.0",
    "clsx": "^2.1.1",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "next": "^15.5.19",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "youtube-dl-exec": "^3.0.12",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "prisma": "^6.3.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
